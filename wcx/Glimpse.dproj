<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{C8F5B3E2-6D9A-4F7B-A0C1-3E4F5A6B7C8D}</ProjectGuid>
        <ProjectVersion>20.3</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <MainSource>Glimpse.dpr</MainSource>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Release</Config>
        <Platform Condition="'$(Platform)'==''">Win64</Platform>
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Library</AppType>
        <ProjectName Condition="'$(ProjectName)'==''">Glimpse</ProjectName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
        <DCC_Define>DEBUG;$(DCC_Define)</DCC_Define>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win64)'!=''">
        <Cfg_2_Win64>true</Cfg_2_Win64>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Base)'!=''">
        <GenDll>true</GenDll>
        <SanitizedProjectName>Glimpse</SanitizedProjectName>
        <DCC_ExeOutput>.\$(Platform)\$(Config)</DCC_ExeOutput>
        <DCC_DcuOutput>.\$(Platform)\$(Config)\dcu</DCC_DcuOutput>
        <DCC_UnitSearchPath>Core;Forms;Presenters;Entries;Services;Settings;Util;..\src;..\src\domain;..\src\domain\Frame;..\src\domain\Render;..\src\domain\Settings;..\src\domain\StatusBar;..\src\domain\Hotkeys;..\src\domain\Clipboard;..\src\domain\Video;..\src\domain\Cache;..\src\application;..\src\infrastructure;..\src\shared;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Cfg_2_Win64)'!=''">
        <DCC_AssertionsAtRuntime>false</DCC_AssertionsAtRuntime>
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <DCC_LocalDebugSymbols>false</DCC_LocalDebugSymbols>
        <DCC_SymbolReferenceInfo>0</DCC_SymbolReferenceInfo>
        <VerInfo_Locale>1049</VerInfo_Locale>
        <DCC_ImportedDataReferences>false</DCC_ImportedDataReferences>
        <Manifest_File>(None)</Manifest_File>
        <AppDPIAwarenessMode>none</AppDPIAwarenessMode>
    </PropertyGroup>
    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <DCCReference Include="..\src\domain\Types.pas"/>
        <DCCReference Include="..\src\domain\StatusBar\StatusBarLayout.pas"/>
        <DCCReference Include="Core\WcxAPI.pas"/>
        <DCCReference Include="Core\WcxExports.pas"/>
        <DCCReference Include="Settings\WcxSettings.pas"/>
        <DCCReference Include="Forms\WcxSettingsDlg.pas">
            <Form>WcxSettingsForm</Form>
        </DCCReference>
        <DCCReference Include="..\src\domain\Frame\FrameOffsets.pas"/>
        <DCCReference Include="..\src\infrastructure\FFmpegLocator.pas"/>
        <DCCReference Include="..\src\infrastructure\FFmpegExe.pas"/>
        <DCCReference Include="..\src\shared\Logging.pas"/>
        <DCCReference Include="..\src\infrastructure\CacheStorage.pas"/>
        <DCCReference Include="..\src\infrastructure\LruEvictionPolicy.pas"/>
        <DCCReference Include="..\src\domain\Cache\Cache.pas"/>
        <DCCReference Include="..\src\domain\Cache\CacheKey.pas"/>
        <DCCReference Include="..\src\domain\Cache\ProbeCache.pas"/>
        <DCCReference Include="..\src\domain\Frame\FrameFileNames.pas"/>
        <DCCReference Include="..\src\domain\Render\BitmapSaver.pas"/>
        <DCCReference Include="..\src\domain\Frame\ExtractionPlanner.pas"/>
        <DCCReference Include="..\src\domain\Render\BitmapResize.pas"/>
        <DCCReference Include="..\src\shared\PathExpand.pas"/>
        <DCCReference Include="..\src\domain\Render\ColorConv.pas"/>
        <DCCReference Include="..\src\infrastructure\ProcessRunner.pas"/>
        <DCCReference Include="..\src\domain\Settings\Defaults.pas"/>
        <DCCReference Include="..\src\domain\Frame\FrameExtractor.pas"/>
        <DCCReference Include="..\src\domain\Render\BannerInfo.pas"/>
        <DCCReference Include="..\src\domain\Render\BannerPainter.pas"/>
        <DCCReference Include="..\src\domain\Render\CombinedGrid.pas"/>
        <DCCReference Include="..\src\domain\Render\TimecodeOverlay.pas"/>
        <DCCReference Include="..\src\domain\Render\RenderDefaults.pas"/>
        <DCCReference Include="..\src\shared\PluginMessages.pas"/>
        <DCCReference Include="..\src\domain\Video\VideoProbing.pas"/>
        <DCCReference Include="Services\WcxFrameCache.pas"/>
        <DCCReference Include="Services\PresetExtractReporter.pas"/>
        <DCCReference Include="Services\WcxProgressCallback.pas"/>
        <DCCReference Include="..\src\domain\Video\VideoInfo.pas"/>
        <DCCReference Include="..\src\infrastructure\LineSplitter.pas"/>
        <DCCReference Include="..\src\infrastructure\FFmpegProbeParser.pas"/>
        <DCCReference Include="..\src\infrastructure\FFmpegCmdLine.pas"/>
        <DCCReference Include="..\src\infrastructure\IniEncoding.pas"/>
        <DCCReference Include="..\src\infrastructure\IniDocument.pas"/>
        <DCCReference Include="..\src\domain\Settings\SettingsInterfaces.pas"/>
        <DCCReference Include="..\src\domain\Settings\Settings.pas"/>
        <DCCReference Include="..\src\domain\Hotkeys\Hotkeys.pas"/>
        <DCCReference Include="..\src\domain\Hotkeys\HotkeysCodec.pas"/>
        <DCCReference Include="..\src\domain\Hotkeys\HotkeysDisplay.pas"/>
        <DCCReference Include="..\src\application\SettingsDlgLogic.pas"/>
        <DCCReference Include="..\src\infrastructure\SettingsDlgUI.pas"/>
        <DCCReference Include="Entries\WcxEntryExtractors.pas"/>
        <DCCReference Include="Core\WcxArchiveHandle.pas"/>
        <DCCReference Include="Util\WcxErrorMapping.pas"/>
        <DCCReference Include="Services\WcxExtractionController.pas"/>
        <DCCReference Include="Core\WcxArchiveCoordinator.pas"/>
        <DCCReference Include="Services\SettingsSaveOrchestrator.pas"/>
        <DCCReference Include="Settings\WcxSettingsRepository.pas"/>
        <DCCReference Include="Entries\WcxPresetsRepository.pas"/>
        <DCCReference Include="Presenters\WcxSettingsControlsBundles.pas"/>
        <DCCReference Include="..\src\infrastructure\SettingsDialogHelpers.pas"/>
        <DCCReference Include="Presenters\WcxSettingsPresenters.pas"/>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>LibraryType</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Excluded_Packages>
                    <Excluded_Packages Name="$(BDSBIN)\dcloffice2k280.bpl">Microsoft Office 2000 Sample Automation Server Wrapper Components</Excluded_Packages>
                    <Excluded_Packages Name="$(BDSBIN)\dclofficexp280.bpl">Microsoft Office XP Sample Automation Server Wrapper Components</Excluded_Packages>
                </Excluded_Packages>
                <Source>
                    <Source Name="MainSource">Glimpse.dpr</Source>
                </Source>
            </Delphi.Personality>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>
    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
</Project>

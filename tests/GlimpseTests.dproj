        <DCC_UnitSearchPath>application;domain;domain\Cache;domain\Clipboard;domain\Frame;domain\Hotkeys;domain\Render;domain\Settings;domain\StatusBar;domain\Video;infrastructure;shared;wcx\Core;wcx\Entries;wcx\Presenters;wcx\Services;wcx\Settings;wcx\Util;wlx\Commands;wlx\Controllers;wlx\Core;wlx\Hotkeys;wlx\Presenters;wlx\Services;wlx\Toolbar;wlx\ViewMode;wlx\Widgets;..\wcx\Core;..\wcx\Forms;..\wcx\Presenters;..\wcx\Entries;..\wcx\Services;..\wcx\Settings;..\wcx\Util;..\wlx\Core;..\wlx\Forms;..\wlx\Widgets;..\wlx\Controllers;..\wlx\Presenters;..\wlx\Services;..\wlx\Toolbar;..\wlx\ViewMode;..\wlx\Hotkeys;..\wlx\Commands;..\wlx\Util;..\src;..\src\domain;..\src\domain\Frame;..\src\domain\Render;..\src\domain\Settings;..\src\domain\StatusBar;..\src\domain\Hotkeys;..\src\domain\Clipboard;..\src\domain\Video;..\src\domain\Cache;..\src\application;..\src\infrastructure;..\src\shared;..\wlx;..\wcx;$(DCC_UnitSearchPath)</DCC_UnitSearchPath>
